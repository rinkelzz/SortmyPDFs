# Microsoft Graph App Registration
# Für OneDrive Personal: tenant = consumers
GRAPH_TENANT=consumers
GRAPH_CLIENT_ID=

# Scopes (space-separated)
GRAPH_SCOPES="Files.ReadWrite.All"

# OneDrive folder (relative to root)
ONEDRIVE_INBOX=vomDrucker
ONEDRIVE_TARGET_ROOT=SortmyPDFs

# IMAP source for PDF attachments
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# Web portal credentials (see web_portals.json)
WWK_USER=
WWK_PASS=
