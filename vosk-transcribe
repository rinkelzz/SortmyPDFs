#!/usr/bin/env bash
set -euo pipefail
AUDIO_PATH="${1:-}"
if [[ -z "$AUDIO_PATH" ]]; then
  echo "Usage: vosk-transcribe <audio-file>" >&2
  exit 2
fi

# Use the dedicated venv we created in the workspace.
VENV="/home/tim/.openclaw/workspace/.venv-vosk"
PY="$VENV/bin/python"

if [[ ! -x "$PY" ]]; then
  echo "Missing venv python at $PY. Create it with: python3 -m venv $VENV && source $VENV/bin/activate && pip install vosk" >&2
  exit 3
fi

exec "$PY" /home/tim/.openclaw/workspace/vosk_transcribe.py "$AUDIO_PATH"
